{
  "_comment": "Canonical schemas for the 7 sub-sheets freight-onboard creates inside the operator-provided WeCom smartsheet docs. Mirrors references/wecom-sheet-schemas.md and the two production reference workbenches. Field types use wecom-cli's FIELD_TYPE_* enums per https://github.com/WecomTeam/wecom-cli/blob/main/skills/wecomcli-smartsheet/references/smartsheet-field-types.md",
  "scenarios": {
    "1": {
      "description": "Lead profiling workbench (拓客). Operator pre-creates ONE empty smartsheet doc in WeCom UI and provides its docid.",
      "sheets": [
        {
          "title": "客户线索表",
          "fields": [
            {"field_title": "公司名", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "官网", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "联系人", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "来源渠道", "field_type": "FIELD_TYPE_TEXT"}
          ]
        },
        {
          "title": "待审核开发信",
          "fields": [
            {"field_title": "客户名", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "官网", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "联系人", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "来源渠道", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "信息获取状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "主营业务摘要", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "市场定位", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "潜在需求分析", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "与我司业务匹配度", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "画像摘要", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "开发信草稿", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "审核状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "人工指定发送渠道", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "异常原因", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "更新时间", "field_type": "FIELD_TYPE_TEXT"}
          ]
        }
      ]
    },
    "2": {
      "description": "Daily rate promotion workbench (运价推广). Operator pre-creates ONE empty smartsheet doc in WeCom UI and provides its docid.",
      "sheets": [
        {
          "title": "运价表（人）",
          "fields": [
            {"field_title": "区域", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "POD", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "船公司", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "20GP", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "40GP", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "40HQ", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "有效期", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "POL", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "超重费标准和其他费用", "field_type": "FIELD_TYPE_TEXT"}
          ]
        },
        {
          "title": "运价信息（人）",
          "fields": [
            {"field_title": "入库日期", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "区域", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "段落标题", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "原文", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "来源", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "解析状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "备注", "field_type": "FIELD_TYPE_TEXT"}
          ]
        },
        {
          "title": "每日简报（AI）",
          "fields": [
            {"field_title": "日期", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "简报标题", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "推广审核状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "备注", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "更新时间", "field_type": "FIELD_TYPE_TEXT"}
          ]
        },
        {
          "title": "推广审核（AI+人）",
          "fields": [
            {"field_title": "推广标题", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "推广信息草稿", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "内部依据摘要", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "成本价检查", "field_type": "FIELD_TYPE_CHECKBOX"},
            {"field_title": "审核状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "目标客户/分组", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "人工指定发送渠道", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "更新时间", "field_type": "FIELD_TYPE_TEXT"}
          ]
        },
        {
          "title": "发送记录（AI）",
          "fields": [
            {"field_title": "发送时间", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "客户名", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "联系人", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "邮箱", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "航线/区域", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "邮件主题", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "发送状态", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "错误原因", "field_type": "FIELD_TYPE_TEXT"},
            {"field_title": "回复状态", "field_type": "FIELD_TYPE_TEXT"}
          ]
        }
      ]
    }
  }
}
